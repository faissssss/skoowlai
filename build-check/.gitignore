# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# Database files (SECURITY: Never commit databases)
*.db
*.db-shm
*.db-wal
dev.db
prisma/dev.db

# Temporary test files (SECURITY: May contain test data)
.tmp-llm-tests/

# User uploads (SECURITY: May contain PII)
public/uploads/

# Local utility scripts (SECURITY: May contain hardcoded values)
kill_port.ps1
*.local.ps1
*.local.sh

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

{
  "functions": {
    "src/app/api/generate/route.ts": {
      "maxDuration": 120,
      "memory": 1024
    },
    "src/app/api/generate-audio-notes/route.ts": {
      "maxDuration": 120,
      "memory": 1024
    }
  },
  "crons": [
    {
      "path": "/api/cron/keep-alive",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/subscription-reminders",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/normalize-subscriptions",
      "schedule": "30 3 * * *"
    },
    {
      "path": "/api/cron/subscription-sync",
      "schedule": "0 22 * * *"
    }
  ]
}
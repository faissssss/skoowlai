# ============================================
# DATABASE & INFRASTRUCTURE
# ============================================
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token_here
REDIS_URL=https://your-redis-instance.upstash.io

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
CLERK_WEBHOOK_SIGNING_SECRET=whsec_your_clerk_webhook_secret
NEXT_PUBLIC_CLERK_PRICE_ID=cplan_your_clerk_price_id

# Cron Job Authentication
CRON_SECRET=your_secure_random_cron_secret_here

# Admin User IDs (comma-separated Clerk user IDs)
ADMIN_USER_IDS=user_abc123,user_def456

# Debug Endpoints Secret
DEBUG_ENDPOINTS_SECRET=your_debug_secret_here
FIX_SUBSCRIPTION_SECRET=your_fix_subscription_secret_here

# ============================================
# LLM PROVIDERS (Server-Only)
# ============================================
GOOGLE_GENERATIVE_AI_API_KEY=AIzaSy_your_gemini_api_key_here
GROQ_API_KEY=gsk_your_groq_api_key_here
DEEPGRAM_API_KEY=your_deepgram_api_key_here
SUPADATA_API_KEY=sd_your_supadata_api_key_here
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_your_blob_token_here

# LLM Configuration
PRIMARY_LLM_PROVIDER=groq
FALLBACK_LLM_PROVIDER=gemini
ENABLE_LLM_FALLBACK=true
ENABLE_CONTENT_SIZE_ROUTING=true
CONTENT_SIZE_THRESHOLD_TOKENS=20000
GROQ_CONTEXT_LIMIT_TOKENS=120000
LLM_MIGRATION_ENABLED=true
LLM_MODEL_MAPPING={"generate":{"provider":"groq","model":"llama-3.3-70b-versatile","priority":"high"}}

# ============================================
# PAYMENT PROVIDERS (Server-Only)
# ============================================
# Dodo Payments
DODO_PAYMENTS_API_KEY=your_dodo_api_key_here
DODO_PAYMENTS_WEBHOOK_KEY=whsec_your_dodo_webhook_key_here
DODO_PAYMENTS_ENVIRONMENT=test_mode
DODO_PAYMENTS_RETURN_URL=https://yourdomain.com/dashboard

# Dodo Product IDs (Safe to expose - NEXT_PUBLIC_)
NEXT_PUBLIC_DODO_MONTHLY_PRODUCT_ID=pdt_your_monthly_product_id
NEXT_PUBLIC_DODO_YEARLY_PRODUCT_ID=pdt_your_yearly_product_id
NEXT_PUBLIC_DODO_MONTHLY_NO_TRIAL_PRODUCT_ID=pdt_your_monthly_no_trial_id
NEXT_PUBLIC_DODO_YEARLY_NO_TRIAL_PRODUCT_ID=pdt_your_yearly_no_trial_id
NEXT_PUBLIC_DODO_STUDENT_MONTHLY_PRODUCT_ID=pdt_your_student_monthly_id
NEXT_PUBLIC_DODO_STUDENT_YEARLY_PRODUCT_ID=pdt_your_student_yearly_id

# PayPal
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id
NEXT_PAYPAL_SECRET=your_paypal_secret_here
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id
NEXT_PUBLIC_PAYPAL_MONTHLY_PLAN_ID=P-your_monthly_plan_id
NEXT_PUBLIC_PAYPAL_YEARLY_PLAN_ID=P-your_yearly_plan_id

# ============================================
# EMAIL & NOTIFICATIONS (Server-Only)
# ============================================
RESEND_API_KEY=re_your_resend_api_key_here

# Discord Webhooks
DISCORD_BUGREPORTS_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_url
DISCORD_FEEDBACKS_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_url

# ============================================
# APPLICATION CONFIGURATION (Safe to expose)
# ============================================
NEXT_PUBLIC_APP_URL=https://yourdomain.com
CSRF_ALLOWED_ORIGINS=https://yourdomain.com

# ============================================
# NOTES
# ============================================
# Server-Only Secrets (NEVER prefix with NEXT_PUBLIC_):
#   - All API keys (GROQ_API_KEY, GOOGLE_GENERATIVE_AI_API_KEY, etc.)
#   - Database URLs (DATABASE_URL)
#   - Webhook secrets (CLERK_WEBHOOK_SIGNING_SECRET, DODO_PAYMENTS_WEBHOOK_KEY)
#   - Authentication secrets (CLERK_SECRET_KEY, CRON_SECRET)
#   - Payment secrets (NEXT_PAYPAL_SECRET, DODO_PAYMENTS_API_KEY)
#
# Safe to Expose (NEXT_PUBLIC_ prefix):
#   - Product IDs (NEXT_PUBLIC_DODO_MONTHLY_PRODUCT_ID)
#   - Publishable keys (NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY)
#   - Public URLs (NEXT_PUBLIC_APP_URL)
#   - Client IDs (NEXT_PUBLIC_PAYPAL_CLIENT_ID)
